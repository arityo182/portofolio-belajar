# ============================================
# RS Medika Sentosa — .gitignore
# ============================================

# Environment (credentials)
.env
!.env.example
*.local

# IDE
.idea/
*.iml
*.swp
*.swo
*~
.vscode/

# OS
.DS_Store
Thumbs.db
Desktop.ini

# ============================================
# Backend (Spring Boot / Gradle)
# ============================================
medikasentosa/.gradle/
medikasentosa/build/
medikasentosa/bin/
medikasentosa/out/

# ============================================
# Frontend (React / Node)
# ============================================
hospital-frontend/node_modules/
hospital-frontend/dist/
hospital-frontend/.vite/

# ============================================
# ML Service (Python)
# ============================================
ml-service/venv/
ml-service/__pycache__/
ml-service/**/__pycache__/
ml-service/*.pyc
ml-service/*.pyo

# Model files (TERLALU BESAR — 250MB+ each)
ml-service/models/*.keras
ml-service/models/*.h5
ml-service/models/*.hdf5
!ml-service/models/.gitkeep

# ============================================
# Docker / Data / Logs
# ============================================
docker-volumes/
*.log
*.pid

# Offline packages (dari disasterwatch script)
offline-packages/

# Backup files
*.bak
*.backup
*.tar
*.tar.gz
