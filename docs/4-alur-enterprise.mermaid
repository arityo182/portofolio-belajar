flowchart TD
    PASIEN([Pasien])
    DOKTER([Dokter])
    ADMIN([Admin])

    %% AUTH
    PASIEN --> LOGIN[Login / Register]
    DOKTER --> LOGIN
    ADMIN --> LOGIN
    LOGIN --> USERS[(users)]

    %% PENDAFTARAN & BOOKING
    PASIEN --> DAFTAR[Daftar Pasien]
    DAFTAR --> TPASIEN[(pasien)]
    PASIEN --> BOOKING[Booking Appointment]
    BOOKING --> TJADWAL[(jadwal_dokter)]
    BOOKING --> TAPPT[(appointment)]
    TAPPT --> TANTRIAN[(antrian)]

    %% PEMERIKSAAN
    TANTRIAN --> PERIKSA[Diperiksa Dokter]
    DOKTER --> PERIKSA
    PERIKSA --> TREKAM[(rekam_medis)]
    TREKAM --> TRESEP[(resep)]
    TRESEP --> TOBAT[(obat)]

    %% PENUNJANG FASE 2
    TREKAM -.->|perlu tes| TLAB[(lab_order)]
    TLAB --> TLABHASIL[(lab_hasil)]
    TREKAM -.->|perlu citra| TRADIO[(radiologi)]
    TRADIO -.->|X-ray osteo| SCREEN[Skrining AI]
    SCREEN --> TSCREEN[(screening)]
    TREKAM -.->|rawat inap| TRAWAT[(rawat_inap)]
    TRAWAT --> TKAMAR[(kamar)]
    TREKAM -.->|operasi| TOPERASI[(jadwal_operasi)]

    %% KEUANGAN FASE 3
    TREKAM --> TBILLING[(billing)]
    TRAWAT -.-> TBILLING
    TBILLING --> TITEM[(billing_item)]
    TBILLING --> BAYAR[Pembayaran]
    BAYAR --> TBAYAR[(pembayaran)]
    BAYAR -.->|ditunda| BPJS[BPJS - nanti]

    %% CHATBOT SENTA (Fase 2)
    PASIEN -.->|tanya kesehatan| SENTA[Chatbot Senta - Qwen/vLLM]
    SENTA --> TCHATSESSION[(chat_session)]
    TCHATSESSION --> TCHATMSG[(chat_message)]

    %% ADMIN
    ADMIN --> KELOLA[Kelola Master Data]
    KELOLA --> TPOLI[(poli)]
    KELOLA --> TDOKTER[(dokter)]
    KELOLA --> TOBAT

    classDef mvp fill:#E4F4FD,stroke:#172E74,color:#172E74
    classDef fase2 fill:#F8F8EF,stroke:#545454,color:#545454,stroke-dasharray: 4
    classDef fase3 fill:#FDEBD7,stroke:#EF7A00,color:#7A3D00
    classDef aktor fill:#172E74,stroke:#172E74,color:#fff
    classDef proses fill:#3EAFEF,stroke:#172E74,color:#fff

    class PASIEN,DOKTER,ADMIN aktor
    class USERS,TPASIEN,TJADWAL,TAPPT,TANTRIAN,TREKAM,TRESEP,TSCREEN,TPOLI,TDOKTER mvp
    class TLAB,TLABHASIL,TRADIO,TRAWAT,TKAMAR,TOPERASI,TOBAT,TCHATSESSION,TCHATMSG fase2
    class TBILLING,TITEM,TBAYAR,BPJS fase3
    class LOGIN,DAFTAR,BOOKING,PERIKSA,SCREEN,BAYAR,KELOLA,SENTA proses
